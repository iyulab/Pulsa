{
  "Update": {
    "Enabled": true,
    "Repository": "iyulab/Pulsa",
    "TagPrefix": "stt-v",
    "AssetPattern": "PulsaSTT-win-x64.zip"
  },
  "Stt": {
    "WatchPath": ".",
    "FilePattern": "*.mp3",
    "OutputPattern": "{name}.stt.txt",
    "Model": "large",
    "Language": "",
    "NoSpeechThreshold": 0.8,
    "FileReadyRetries": 20,
    "FileReadyRetryDelayMs": 500,
    "RescanIntervalSeconds": 60
  },
  "LogsPath": "logs",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
