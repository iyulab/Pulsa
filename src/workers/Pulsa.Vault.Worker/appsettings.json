{
  "Update": {
    "Enabled": true,
    "Repository": "iyulab/Pulsa",
    "TagPrefix": "vault-v",
    "AssetPattern": "PulsaVault-win-x64.zip"
  },
  "Vault": {
    "Folders": [
      {
        "Path": ".",
        "IncludePatterns": ["*.md", "*.txt", "*.pdf", "*.docx"],
        "ExcludePatterns": ["*.tmp", "~$*"],
        "Recursive": true
      }
    ]
  },
  "FileVault": {
    "VaultBasePath": "./data/vault",
    "MaxFileSizeMB": 100,
    "EnableRealTimeWatch": true,
    "DebounceDelayMs": 500,
    "MaxConcurrentProcessing": 4
  },
  "VectorStore": {
    "Provider": "SQLite",
    "SQLite": {
      "DatabasePath": "./data/vault-vectors.db"
    },
    "PostgreSQL": {
      "ConnectionString": ""
    }
  },
  "Embedding": {
    "Provider": "",
    "OpenAI": {
      "Endpoint": "https://api.openai.com/v1",
      "ApiKey": "",
      "Model": "text-embedding-3-small",
      "Dimension": 1536
    },
    "LMSupply": {
      "ModelId": "default"
    }
  },
  "Mcp": {
    "Name": "PulsaVault",
    "Version": "0.1.0",
    "Instructions": "Knowledge base search server for local documents"
  },
  "LogsPath": "logs"
}
