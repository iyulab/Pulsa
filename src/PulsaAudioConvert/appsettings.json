{
  "Update": {
    "Enabled": true,
    "Repository": "iyulab/Pulsa",
    "TagPrefix": "audio-convert-v",
    "AssetPattern": "PulsaAudioConvert-win-x64.zip"
  },
  "Convert": {
    "WatchPath": ".",
    "FilePattern": "*.m4a",
    "OutputExtension": ".mp3",
    "AudioCodec": "libmp3lame",
    "AudioBitrate": 192,
    "DeleteSource": false,
    "FileReadyRetries": 10,
    "FileReadyRetryDelayMs": 500,
    "RescanIntervalSeconds": 60
  },
  "LogsPath": "logs",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
