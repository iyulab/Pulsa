{
  "Update": {
    "Enabled": true,
    "Repository": "iyulab/Pulsa",
    "TagPrefix": "audio-convert-v",
    "AssetPattern": "PulsaAudioConvert-win-x64.zip"
  },
  "Tasks": [
    {
      "Name": "default",
      "WatchPath": ".",
      "FilePattern": "*.m4a",
      "OutputExtension": ".mp3",
      "AudioCodec": "libmp3lame",
      "AudioBitrate": 192,
      "DeleteSource": false
    }
  ],
  "LogsPath": "logs"
}
